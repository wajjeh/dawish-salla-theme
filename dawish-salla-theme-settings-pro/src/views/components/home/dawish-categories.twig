<section class="dawish-section dawish-categories">
  <div class="container">
    <div class="dawish-section__head">
      <h2>{{ component.title|default('الأقسام') }}</h2>
      <a href="/categories">عرض الكل</a>
    </div>

    <div class="dawish-categories__grid">
      {% if component.categories and component.categories|length %}
        {% for cat in component.categories %}
          <a class="dawish-category-card" href="{{ cat.url }}">
            <span class="dawish-category-card__image">
              {% if cat.image %}<img src="{{ cat.image }}" alt="{{ cat.name }}">{% else %}<i class="sicon-leaf"></i>{% endif %}
            </span>
            <strong>{{ cat.name }}</strong>
          </a>
        {% endfor %}
      {% else %}
        {% set fallback = [
          {'name':'الأعشاب','url':'/search?q=أعشاب','icon':'sicon-leaf'},
          {'name':'الزيوت','url':'/search?q=زيوت','icon':'sicon-drop'},
          {'name':'القهوة','url':'/search?q=قهوة','icon':'sicon-coffee'},
          {'name':'الشاي','url':'/search?q=شاي','icon':'sicon-cup'},
          {'name':'العناية بالشعر','url':'/search?q=العناية بالشعر','icon':'sicon-user'},
          {'name':'العناية بالجسم','url':'/search?q=العناية بالجسم','icon':'sicon-heart'}
        ] %}
        {% for item in fallback %}
          <a class="dawish-category-card" href="{{ item.url }}">
            <span class="dawish-category-card__image"><i class="{{ item.icon }}"></i></span>
            <strong>{{ item.name }}</strong>
          </a>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>
