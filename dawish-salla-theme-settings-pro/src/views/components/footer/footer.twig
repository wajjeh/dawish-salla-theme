<footer class="dawish-footer {{ theme.settings.get('footer_is_dark', false) ? 'is-dark' : 'is-light' }}">
  <div class="container dawish-footer__grid">
    <div>
      {% if theme.settings.get('show_footer_logo', true) %}
      <a class="dawish-footer__brand" href="/">
        {% if store.logo %}<img src="{{ store.logo }}" alt="{{ store.name }}">{% else %}<strong>{{ store.name }}</strong>{% endif %}
      </a>
      {% endif %}
      <p>{{ store.description|default('عطارة الدويش — منتجات مختارة بعناية.') }}</p>
    </div>

    <div>
      <h3>روابط مهمة</h3>
      <a href="/categories">الأقسام</a>
      <a href="/offers">العروض</a>
      <a href="/latest-products">وصل حديثًا</a>
      <a href="/pages/contact-us">تواصل معنا</a>
    </div>

    <div>
      <h3>خدمة العملاء</h3>
      <a href="/orders/tracking">تتبع الطلب</a>
      <a href="/pages/refund-policy">سياسة الاستبدال والاسترجاع</a>
      <a href="/pages/privacy-policy">سياسة الخصوصية</a>
      <a href="/pages/terms-and-conditions">الشروط والأحكام</a>
    </div>

    {% if theme.settings.get('show_footer_contact', true) %}
    <div>
      <h3>تواصل معنا</h3>
      {% if store.contacts.whatsapp %}<a href="https://wa.me/{{ store.contacts.whatsapp }}">واتساب</a>{% endif %}
      {% if store.contacts.mobile %}<a href="tel:{{ store.contacts.mobile }}">{{ store.contacts.mobile }}</a>{% endif %}
      {% if store.contacts.email %}<a href="mailto:{{ store.contacts.email }}">{{ store.contacts.email }}</a>{% endif %}
      {% if theme.settings.get('show_footer_social', true) %}
      <div class="dawish-footer__social">
        {% if store.social.instagram %}<a href="{{ store.social.instagram }}" aria-label="Instagram"><i class="sicon-instagram"></i></a>{% endif %}
        {% if store.social.snapchat %}<a href="{{ store.social.snapchat }}" aria-label="Snapchat"><i class="sicon-snapchat"></i></a>{% endif %}
        {% if store.social.twitter %}<a href="{{ store.social.twitter }}" aria-label="X"><i class="sicon-twitter"></i></a>{% endif %}
      </div>
      {% endif %}
    </div>
    {% endif %}
  </div>

  <div class="container dawish-footer__bottom">
    <span>© {{ "now"|date("Y") }} {{ store.name }}. جميع الحقوق محفوظة.</span>
  </div>
</footer>
