<section class="dawish-hero">
  <div class="container dawish-hero__grid">
    <div class="dawish-hero__content">
      <span class="dawish-eyebrow">منتجات طبيعية مختارة</span>
      <h1>{{ component.title|default(store.name) }}</h1>
      <p>{{ component.description|default(store.description) }}</p>
      <div class="dawish-hero__actions">
        <a href="{{ component.primary_url|default('/categories') }}" class="dawish-btn dawish-btn--primary">تسوق الآن</a>
        <a href="{{ component.secondary_url|default('/offers') }}" class="dawish-btn dawish-btn--ghost">العروض</a>
      </div>
    </div>

    <div class="dawish-hero__visual" aria-hidden="true">
      {% if component.image %}
        <img src="{{ component.image }}" alt="">
      {% elseif store.logo %}
        <div class="dawish-hero__logo-card"><img src="{{ store.logo }}" alt=""></div>
      {% else %}
        <div class="dawish-hero__logo-card"><strong>{{ store.name }}</strong></div>
      {% endif %}
      <span class="dawish-leaf dawish-leaf--1"></span>
      <span class="dawish-leaf dawish-leaf--2"></span>
    </div>
  </div>
</section>
