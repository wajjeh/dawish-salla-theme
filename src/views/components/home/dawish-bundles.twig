<section class="dawish-section dawish-bundles">
  <div class="container">
    <div class="dawish-section__head">
      <div>
        <span class="dawish-eyebrow">{{ component.badge|default('باقات الدويش') }}</span>
        <h2>{{ component.title|default('باقات ترفع قيمة الطلب') }}</h2>
        {% if component.description %}<p>{{ component.description }}</p>{% endif %}
      </div>
      {% if component.display_all_url %}<a href="{{ component.display_all_url }}">عرض الكل</a>{% endif %}
    </div>

    <div class="dawish-bundles__grid">
      {% if component.items and component.items|length %}
        {% for item in component.items %}
          <a class="dawish-bundle-card" href="{{ item.url|default('/categories') }}">
            <span class="dawish-bundle-card__badge">{{ item.badge|default('باقة') }}</span>
            {% if item.image %}<img src="{{ item.image }}" alt="{{ item.title }}">{% else %}<i class="{{ item.icon|default('sicon-leaf') }}"></i>{% endif %}
            <h3>{{ item.title }}</h3>
            <p>{{ item.text }}</p>
            <strong>{{ item.button|default('استعرض الباقة') }}</strong>
          </a>
        {% endfor %}
      {% else %}
        <a class="dawish-bundle-card" href="/search?q=قهوة"><span class="dawish-bundle-card__badge">الأكثر طلبًا</span><i class="sicon-coffee"></i><h3>باقة القهوة والشاي</h3><p>اختيارات مناسبة للجلسات اليومية.</p><strong>استعرض الباقة</strong></a>
        <a class="dawish-bundle-card" href="/search?q=زيوت"><span class="dawish-bundle-card__badge">عناية</span><i class="sicon-drop"></i><h3>باقة الزيوت المختارة</h3><p>منتجات عناية مرتبة في مكان واحد.</p><strong>استعرض الزيوت</strong></a>
        <a class="dawish-bundle-card" href="/offers"><span class="dawish-bundle-card__badge">عرض</span><i class="sicon-gift"></i><h3>باقة الهدايا والعروض</h3><p>منتجات مناسبة للإهداء والتجربة.</p><strong>شاهد العروض</strong></a>
      {% endif %}
    </div>
  </div>
</section>
