<section class="dawish-section dawish-story">
  <div class="container dawish-story__box">
    <div class="dawish-story__content">
      <span class="dawish-eyebrow">{{ component.badge|default('عن عطارة الدويش') }}</span>
      <h2>{{ component.title|default('اختيار طبيعي بتجربة شراء أوضح') }}</h2>
      <p>{{ component.text|default('صممنا المتجر ليكون واضحًا وسهلًا، من البحث عن المنتج وحتى إتمام الطلب. كل قسم مرتب بطريقة تساعد العميل يصل للمنتج بسرعة.') }}</p>
      <div class="dawish-story__stats">
        <div><strong>24/7</strong><span>تسوق إلكتروني</span></div>
        <div><strong>آمن</strong><span>دفع وطلب</span></div>
        <div><strong>سريع</strong><span>وصول للمنتج</span></div>
      </div>
    </div>
    <div class="dawish-story__visual">
      {% if component.image %}
        <img src="{{ component.image }}" alt="{{ component.title }}">
      {% elseif store.logo %}
        <img src="{{ store.logo }}" alt="{{ store.name }}">
      {% else %}
        <strong>{{ store.name }}</strong>
      {% endif %}
    </div>
  </div>
</section>
