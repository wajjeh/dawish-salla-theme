{#
  Dawish Herbal Theme - master layout.
  Uses Salla/Twilight shared variables such as store.logo, store.name, theme.settings and cart.
#}
{{ theme.settings.set('placeholder', theme.settings.get('placeholder', 'images/placeholder.png')) }}
<!doctype html>
<html lang="{{ user.language.code|default('ar') }}" dir="{{ theme.is_rtl ? 'rtl' : 'ltr' }}">
<head>
  {% hook 'head:start' %}
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="{{ theme.settings.get('dawish_primary_color', '#68744c') }}">
  <title>{% block title %}{{ page.title|default(store.name) }}{% endblock %}</title>
  {% if store.icon %}<link rel="icon" href="{{ store.icon }}">{% endif %}
  {% if theme.font and theme.font.url %}<link rel="stylesheet" href="{{ theme.font.url }}">{% endif %}
  {# If your Salla build uses another asset helper, keep the files and adjust these two lines only. #}
  <link rel="stylesheet" href="{{ 'styles/app.css'|asset }}">
  {% hook head %}
  {% block styles %}{% endblock %}
  {% hook 'head:end' %}
</head>
<body class="dawish-theme {{ theme.is_rtl ? 'is-rtl' : 'is-ltr' }} {{ theme.settings.get('topnav_is_dark', false) ? 'has-dark-topnav' : 'has-light-topnav' }} {{ theme.settings.get('footer_is_dark', false) ? 'has-dark-footer' : 'has-light-footer' }} {{ theme.settings.get('header_is_sticky', true) ? 'has-sticky-header' : '' }}" style="--dawish-olive: {{ theme.settings.get('dawish_primary_color', '#68744c') }}; --dawish-gold: {{ theme.settings.get('dawish_accent_color', '#c2a15a') }}; --dawish-cream: {{ theme.settings.get('dawish_background_color', '#fffaf1') }};">
  <noscript>To get full functionality of this site you need to enable JavaScript.</noscript>
  {% hook 'body:start' %}

  {% if theme.settings.get('dawish_loader_enabled', true) %}
    {% include 'partials/loader.twig' %}
  {% endif %}

  {% component 'header.header' %}

  <main id="dawish-app" class="dawish-main" tabindex="-1">
    {% block content %}{% endblock %}
  </main>

  {% component 'footer.footer' %}

  {% if theme.settings.get('dawish_search_overlay_enabled', true) %}
    {% include 'partials/search-overlay.twig' %}
  {% endif %}

  {% hook 'body:end' %}
  <script>
    window.dawishTheme = {
      loaderTimeout: {{ theme.settings.get('dawish_loader_timeout', 2500) }},
      stickyHeader: {{ theme.settings.get('header_is_sticky', true) ? 'true' : 'false' }},
      addProductToast: {{ theme.settings.get('enable_add_product_toast', true) ? 'true' : 'false' }},
      imageZoom: {{ theme.settings.get('imageZoom', true) ? 'true' : 'false' }}
    };
  </script>
  <script src="{{ 'js/app.js'|asset }}" defer></script>
  {% block scripts %}{% endblock %}
</body>
</html>
