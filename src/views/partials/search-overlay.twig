<div class="dawish-search-overlay" id="dawish-search-overlay" aria-hidden="true">
  <div class="dawish-search-overlay__shade" data-dawish-close-search></div>
  <section class="dawish-search-overlay__panel" role="dialog" aria-modal="true" aria-labelledby="dawish-search-title">
    <button class="dawish-icon-button dawish-search-overlay__close" type="button" data-dawish-close-search aria-label="إغلاق البحث">
      <i class="sicon-cancel"></i>
    </button>
    <h2 id="dawish-search-title">وش تدور عليه؟</h2>
    <p>{{ theme.settings.get('dawish_search_helper', 'ابحث مباشرة عن الأعشاب، الزيوت، القهوة، الشاي ومنتجات العناية.') }}</p>
    <form action="/search" method="get" class="dawish-search-form">
      <i class="sicon-search"></i>
      <input id="dawish-search-input" type="search" name="q" placeholder="{{ theme.settings.get('dawish_search_placeholder', 'اكتب اسم المنتج أو القسم...') }}" autocomplete="off">
      <button type="submit">بحث</button>
    </form>
    <div class="dawish-search-tags" aria-label="اقتراحات البحث">
      <a href="/search?q=أعشاب">أعشاب</a>
      <a href="/search?q=زيوت">زيوت</a>
      <a href="/search?q=قهوة">قهوة</a>
      <a href="/search?q=شاي">شاي</a>
      <a href="/search?q=العناية">العناية</a>
      <a href="/offers">العروض</a>
    </div>
  </section>
</div>
