{
  "name": {
    "ar": "ثيم الدويش الطبيعي",
    "en": "Dawish Natural Theme"
  },
  "repository": "https://github.com/wajjeh/dawish-salla-theme",
  "author_email": "alal1143@icloud.com",
  "support_url": "https://salla.dev",
  "description": {
    "ar": "ثيم مخصص لعطارة الدويش بهوية طبيعية، شاشة تحميل، صفحة رئيسية جاهزة، وتحسينات للجوال وصفحة المنتج والسلة.",
    "en": "A custom natural storefront theme for Dawish, with loading screen, ready homepage, mobile polish, product and cart improvements."
  },
  "features": [
    "mega-menu",
    "fonts",
    "color",
    "breadcrumb",
    "unite-cards-height",
    "menu-images",
    "filters",
    "component-featured-products",
    "component-fixed-banner",
    "component-fixed-products",
    "component-products-slider",
    "component-photos-slider",
    "component-square-photos",
    "component-store-features",
    "component-testimonials",
    "component-youtube"
  ],
  "settings": [
    {
      "type": "boolean",
      "label": "تثبيت الهيدر عند التمرير",
      "id": "header_is_sticky",
      "format": "switch",
      "value": true,
      "selected": true
    },
    {
      "type": "boolean",
      "label": "تفعيل شاشة التحميل بشعار المتجر",
      "id": "dawish_loader_enabled",
      "format": "switch",
      "value": true,
      "selected": true
    },
    {
      "type": "boolean",
      "label": "إظهار شريط البحث في الجوال",
      "id": "show_mobile_search",
      "format": "switch",
      "value": true,
      "selected": true
    },
    {
      "type": "boolean",
      "label": "إظهار المفضلة في الهيدر",
      "id": "show_wishlist_in_header",
      "format": "switch",
      "value": true,
      "selected": true
    },
    {
      "type": "boolean",
      "label": "إظهار شعار المتجر في الفوتر",
      "id": "show_footer_logo",
      "format": "switch",
      "value": true,
      "selected": true
    },
    {
      "type": "boolean",
      "label": "تثبيت زر الإضافة للسلة في الجوال",
      "id": "sticky_add_to_cart",
      "format": "switch",
      "value": true,
      "selected": true
    },
    {
      "type": "string",
      "label": "لون الثيم الأساسي",
      "id": "dawish_primary_color",
      "format": "color",
      "value": "#68744c"
    },
    {
      "type": "string",
      "label": "لون الخلفية العام",
      "id": "dawish_background_color",
      "format": "color",
      "value": "#fffaf1"
    },
    {
      "type": "string",
      "label": "نص الشريط العلوي",
      "id": "dawish_topbar_text",
      "format": "text",
      "value": "منتجات طبيعية مختارة بعناية — دفع آمن — توصيل سريع",
      "multilanguage": false
    },
    {
      "type": "string",
      "label": "رقم الواتساب",
      "id": "dawish_whatsapp_number",
      "format": "text",
      "value": ""
    }
  ],
  "components": []
}