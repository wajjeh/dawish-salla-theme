<div id="dawish-loader" class="dawish-loader" aria-live="polite" aria-label="جاري تحميل المتجر">
  <div class="dawish-loader__content">
    {% if store.logo %}
      <img src="{{ store.logo }}" alt="{{ store.name }}" class="dawish-loader__logo" loading="eager">
    {% else %}
      <strong class="dawish-loader__name">{{ store.name }}</strong>
    {% endif %}
    <div class="dawish-loader__bar" aria-hidden="true"><span></span></div>
  </div>
</div>
